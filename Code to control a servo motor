from skyfield.api import load, Topos
import serial
import time

port = "COM5"
baud = 115200

lat = 51.5074
lon = -0.1278
height = 20

sat_name = "ISS (ZARYA)"

ser = serial.Serial(
    port,
    baud,
    timeout=1
)

time.sleep(2)

stations = load.tle_file(
    "https://celestrak.org/NORAD/elements/stations.txt"
)

target = None

for sat in stations:
    if sat_name.lower() in sat.name.lower():
        target = sat
        break

if target is None:
    raise Exception("Satellite not found")

print("Tracking:", target.name)

observer = Topos(
    latitude_degrees=lat,
    longitude_degrees=lon,
    elevation_m=height
)

ts = load.timescale()

while True:

    t = ts.now()

    diff = target - observer

    pos = diff.at(t)

    alt, az, distance = pos.altaz()

    elevation = alt.degrees
    azimuth = az.degrees

    if elevation >= 0:

        packet = f"{azimuth:.1f},{elevation:.1f}\n"

        ser.write(
            packet.encode()
        )

        print(
            packet.strip()
        )

    else:

        print(
            "Below horizon"
        )

    time.sleep(1)
